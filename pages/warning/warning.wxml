<!--pages/warning/warning.wxml-->
<view class="page-container">
  <!-- 加载中 -->
  <view wx:if="{{loading}}" class="loading">
    <text>加载中...</text>
  </view>

  <view wx:else class="main-content">
    <!-- 当前风险等级 -->
    <view class="risk-card" style="border-left-color: {{currentRisk.color}};">
      <view class="risk-header">
        <text class="risk-title">当前风险等级</text>
        <text class="risk-level" style="color: {{currentRisk.color}};">{{currentRisk.level}}</text>
      </view>
      
      <!-- 风险进度条 -->
      <view class="risk-progress">
        <view class="progress-bar">
          <view class="progress-fill" style="width: {{currentRisk.score}}%; background-color: {{currentRisk.color}};"></view>
          <view class="progress-indicator" style="left: {{currentRisk.score}}%;"></view>
        </view>
        <view class="progress-labels">
          <text class="progress-label">低风险</text>
          <text class="progress-label">中等风险</text>
          <text class="progress-label">高风险</text>
        </view>
      </view>
      
      <view class="risk-description">
        <text>{{currentRisk.description}}</text>
      </view>
    </view>

    <!-- 预警统计 -->
    <view class="stats-card">
      <view class="stats-header">
        <text class="stats-title">预警统计</text>
        <text class="stats-update">最近7天</text>
      </view>
      
      <view class="stats-grid">
        <view class="stat-item">
          <text class="stat-value">{{warningsStats.total}}</text>
          <text class="stat-label">总预警数</text>
        </view>
        <view class="stat-item">
          <text class="stat-value">{{warningsStats.unhandled}}</text>
          <text class="stat-label">未处理</text>
        </view>
        <view class="stat-item">
          <text class="stat-value">{{warningsStats.highRisk}}</text>
          <text class="stat-label">高风险</text>
        </view>
        <view class="stat-item">
          <text class="stat-value">{{warningsStats.missCheckin}}</text>
          <text class="stat-label">漏打卡</text>
        </view>
      </view>
    </view>

    <!-- 风险原因分析 -->
    <view class="analysis-card">
      <view class="section-header">
        <text class="section-title">风险原因分析</text>
      </view>
      
      <view class="reasons-list">
        <view wx:for="{{riskAnalysis.mainReasons}}" wx:key="type" class="reason-item">
          <view class="reason-header">
            <text class="reason-type">{{item.type}}</text>
            <text class="reason-count">{{item.count}}次 ({{item.percentage}}%)</text>
          </view>
          <view class="reason-bar">
            <view class="bar-fill" style="width: {{item.percentage}}%;"></view>
          </view>
        </view>
      </view>
      
      <view class="suggestions">
        <text class="suggestions-title">改进建议：</text>
        <view wx:for="{{riskAnalysis.suggestions}}" wx:key="index" class="suggestion-item">
          <text class="suggestion-bullet">•</text>
          <text class="suggestion-text">{{item}}</text>
        </view>
      </view>
    </view>

    <!-- 预警列表 -->
    <view class="warnings-card">
      <view class="section-header">
        <text class="section-title">预警列表</text>
        
        <!-- 筛选器 -->
        <view class="filters">
          <view class="filter-group">
            <text class="filter-label">类型：</text>
            <view class="filter-options">
              <text 
                class="filter-option {{filter.type === 'all' ? 'active' : ''}}"
                bindtap="filterWarnings"
                data-type="type"
                data-value="all"
              >全部</text>
              <text 
                class="filter-option {{filter.type === '漏打卡' ? 'active' : ''}}"
                bindtap="filterWarnings"
                data-type="type"
                data-value="漏打卡"
              >漏打卡</text>
              <text 
                class="filter-option {{filter.type === '低评分' ? 'active' : ''}}"
                bindtap="filterWarnings"
                data-type="type"
                data-value="低评分"
              >低评分</text>
            </view>
          </view>
          
          <view class="filter-group">
            <text class="filter-label">状态：</text>
            <view class="filter-options">
              <text 
                class="filter-option {{filter.handled === 'all' ? 'active' : ''}}"
                bindtap="filterWarnings"
                data-type="handled"
                data-value="all"
              >全部</text>
              <text 
                class="filter-option {{filter.handled === 'unhandled' ? 'active' : ''}}"
                bindtap="filterWarnings"
                data-type="handled"
                data-value="unhandled"
              >未处理</text>
              <text 
                class="filter-option {{filter.handled === 'handled' ? 'active' : ''}}"
                bindtap="filterWarnings"
                data-type="handled"
                data-value="handled"
              >已处理</text>
            </view>
          </view>
        </view>
      </view>
      
      <view class="warnings-list">
        <view wx:if="{{warnings.length === 0}}" class="no-warnings">
          <text class="no-data-text">暂无预警记录</text>
          <text class="no-data-hint">继续保持良好的关系状态～</text>
        </view>
        
        <view wx:else class="warning-items">
          <view 
            wx:for="{{warnings}}" 
            wx:key="id"
            class="warning-item {{item.handled ? 'handled' : ''}}"
            bindtap="viewWarningDetail"
            data-id="{{item.id}}"
          >
            <view class="warning-icon" style="background-color: {{item.levelColor}};">
              <text class="icon-text">{{item.typeIcon}}</text>
            </view>
            
            <view class="warning-content">
              <view class="warning-header">
                <text class="warning-type">{{item.type}}</text>
                <text class="warning-level" style="color: {{item.levelColor}};">
                  {{item.level === 'light' ? '轻提醒' : item.level === 'medium' ? '中预警' : '高风险'}}
                </text>
              </view>
              
              <text class="warning-reason">{{item.reason}}</text>
              
              <view class="warning-footer">
                <text class="warning-date">{{item.formattedDate}}</text>
                <text class="warning-status {{item.handled ? 'status-handled' : 'status-unhandled'}}">
                  {{item.handled ? '已处理' : '未处理'}}
                </text>
              </view>
            </view>
            
            <view wx:if="{{!item.handled}}" class="warning-actions">
              <button 
                class="btn-handle" 
                bindtap="handleWarning"
                data-id="{{item.id}}"
                catchtap
              >处理</button>
            </view>
          </view>
        </view>
      </view>
      
      <view wx:if="{{warnings.length > 0}}" class="warnings-footer">
        <text class="clear-filters" bindtap="clearFilters">清除筛选</text>
      </view>
    </view>

    <!-- 处理建议 -->
    <view class="suggestions-card">
      <view class="section-header">
        <text class="section-title">处理建议</text>
      </view>
      
      <view class="suggestion-groups">
        <view wx:for="{{handlingSuggestions}}" wx:key="title" class="suggestion-group">
          <text class="group-title">{{item.title}}</text>
          <view class="group-items">
            <view wx:for="{{item.items}}" wx:key="index" class="group-item">
              <text class="item-bullet">•</text>
              <text class="item-text">{{item2}}</text>
            </view>
          </view>
        </view>
      </view>
    </view>

    <!-- 操作按钮 -->
    <view class="action-buttons">
      <button class="btn btn-primary" bindtap="seekAIHelp">
        <text class="btn-icon">🤖</text>
        <text class="btn-text">寻求AI帮助</text>
      </button>
      
      <button class="btn btn-secondary" bindtap="viewRepairTasks">
        <text class="btn-icon">✅</text>
        <text class="btn-text">查看修复任务</text>
      </button>
      
      <button class="btn btn-warning" bindtap="seekProfessionalHelp">
        <text class="btn-icon">👨‍⚕️</text>
        <text class="btn-text">专业帮助</text>
      </button>
    </view>
  </view>
</view>