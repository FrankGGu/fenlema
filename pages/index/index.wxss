/* pages/index/index.wxss */
.page-container {
  min-height: 100vh;
  background-color: #FFF9F9;
  padding-bottom: 40rpx;
}

/* 状态栏 */
.status-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx 30rpx 20rpx;
  background-color: #FFFFFF;
  border-bottom: 2rpx solid #F0F0F0;
}

.date {
  font-size: 28rpx;
  color: #666666;
}

.user-info {
  display: flex;
  align-items: center;
}

.user-info .avatar {
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  margin-right: 15rpx;
}

.user-info .nickname {
  font-size: 28rpx;
  color: #333333;
}

/* 卡片通用样式 */
.card {
  background-color: #FFFFFF;
  border-radius: 20rpx;
  margin: 30rpx;
  padding: 30rpx;
  box-shadow: 0 4rpx 20rpx rgba(255, 107, 139, 0.08);
}

.card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 25rpx;
  padding-bottom: 20rpx;
  border-bottom: 2rpx solid #F0F0F0;
}

.card-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333333;
}

/* 关系卡片 */
.relationship-days {
  font-size: 24rpx;
  color: #FF6B8B;
  background-color: #FFE8E8;
  padding: 8rpx 16rpx;
  border-radius: 20rpx;
}

/* 温度计 */
.temperature-section {
  margin: 30rpx 0;
}

.temperature-meter {
  width: 100%;
  height: 40rpx;
  background-color: #F0F0F0;
  border-radius: 20rpx;
  overflow: hidden;
  position: relative;
}

.temperature-fill {
  height: 100%;
  border-radius: 20rpx;
  transition: width 0.5s ease;
}

.temperature-indicator {
  position: absolute;
  top: -10rpx;
  width: 4rpx;
  height: 60rpx;
  background-color: #333333;
  transform: translateX(-50%);
}

.temperature-info {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: 15rpx;
}

.temperature-value {
  font-size: 48rpx;
  font-weight: 700;
  color: #333333;
}

.temperature-desc {
  font-size: 24rpx;
  color: #666666;
}

/* 关系信息 */
.relationship-info {
  display: flex;
  justify-content: space-between;
  margin-top: 25rpx;
  padding-top: 25rpx;
  border-top: 2rpx solid #F0F0F0;
}

.info-item {
  display: flex;
  flex-direction: column;
}

.info-label {
  font-size: 24rpx;
  color: #999999;
  margin-bottom: 8rpx;
}

.info-value {
  font-size: 28rpx;
  color: #333333;
  font-weight: 500;
}

.status-1 {
  color: #6BFF8B;
}

.status-2 {
  color: #FFB86B;
}

.status-3 {
  color: #FF6B6B;
}

/* 打卡卡片 */
.checkin-status {
  font-size: 24rpx;
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
}

.not-checkin {
  background-color: #FFE8E8;
  color: #FF6B8B;
}

.checked {
  background-color: #E8FFED;
  color: #6BFF8B;
}

.checkin-details {
  margin-top: 10rpx;
}

.checkin-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #F8F8F8;
}

.checkin-item:last-child {
  border-bottom: none;
}

.checkin-label {
  font-size: 28rpx;
  color: #666666;
  width: 150rpx;
}

.checkin-value {
  font-size: 28rpx;
  font-weight: 500;
}

.mood-1, .conflict-5 {
  color: #FF6B6B;
}

.mood-2, .conflict-4 {
  color: #FFB86B;
}

.mood-3, .conflict-3 {
  color: #666666;
}

.mood-4, .conflict-2 {
  color: #6B8BFF;
}

.mood-5, .conflict-1 {
  color: #6BFF8B;
}

.stars {
  display: flex;
}

.star {
  font-size: 36rpx;
  margin-right: 10rpx;
}

.star.filled {
  color: #FFD700;
}

.star.empty {
  color: #F0F0F0;
}

.checkin-prompt {
  text-align: center;
  padding: 40rpx 0;
}

.checkin-prompt text {
  display: block;
  font-size: 28rpx;
  color: #666666;
  margin-bottom: 30rpx;
}

/* 预警卡片 */
.warning-count {
  font-size: 24rpx;
  color: #FF6B6B;
  background-color: rgba(255, 107, 107, 0.1);
  padding: 8rpx 16rpx;
  border-radius: 20rpx;
}

.warning-list {
  margin-top: 10rpx;
}

.warning-item {
  display: flex;
  align-items: center;
  padding: 25rpx 0;
  border-bottom: 1rpx solid #F8F8F8;
}

.warning-item:last-child {
  border-bottom: none;
}

.warning-icon {
  width: 50rpx;
  height: 50rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  font-weight: bold;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.warning-icon.light {
  background-color: rgba(255, 184, 107, 0.2);
  color: #FFB86B;
}

.warning-icon.medium {
  background-color: rgba(255, 107, 107, 0.2);
  color: #FF6B6B;
}

.warning-icon.high {
  background-color: rgba(255, 107, 107, 0.3);
  color: #FF3333;
}

.warning-content {
  flex: 1;
}

.warning-type {
  display: block;
  font-size: 28rpx;
  font-weight: 500;
  color: #333333;
  margin-bottom: 5rpx;
}

.warning-reason {
  display: block;
  font-size: 24rpx;
  color: #666666;
  margin-bottom: 5rpx;
}

.warning-date {
  display: block;
  font-size: 22rpx;
  color: #999999;
}

.warning-action {
  margin-left: 20rpx;
}

.action-text {
  color: #FF6B8B;
  font-size: 24rpx;
}

.warning-footer {
  text-align: right;
  margin-top: 20rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid #F0F0F0;
}

.warning-footer text {
  color: #666666;
  font-size: 24rpx;
}

/* AI提醒卡片 */
.ai-reminder-card .card-header {
  border-bottom: none;
  padding-bottom: 0;
}

.ai-avatar {
  width: 50rpx;
  height: 50rpx;
  border-radius: 50%;
  margin-right: 15rpx;
}

.ai-content {
  padding: 25rpx;
  background-color: #FFF0F5;
  border-radius: 16rpx;
  margin-top: 20rpx;
}

.ai-text {
  font-size: 28rpx;
  color: #333333;
  line-height: 1.6;
}

.ai-footer {
  text-align: right;
  margin-top: 20rpx;
}

/* 任务卡片 */
.task-count {
  font-size: 24rpx;
  color: #6B8BFF;
  background-color: rgba(107, 139, 255, 0.1);
  padding: 8rpx 16rpx;
  border-radius: 20rpx;
}

.task-list {
  margin-top: 10rpx;
}

.task-item {
  display: flex;
  align-items: center;
  padding: 25rpx 0;
  border-bottom: 1rpx solid #F8F8F8;
}

.task-item:last-child {
  border-bottom: none;
}

.task-checkbox {
  width: 36rpx;
  height: 36rpx;
  border: 2rpx solid #F0F0F0;
  border-radius: 50%;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.task-content {
  flex: 1;
}

.task-title {
  display: block;
  font-size: 28rpx;
  font-weight: 500;
  color: #333333;
  margin-bottom: 5rpx;
}

.task-desc {
  display: block;
  font-size: 24rpx;
  color: #666666;
}

.task-footer {
  text-align: right;
  margin-top: 20rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid #F0F0F0;
}

/* 快捷入口 */
.quick-actions {
  display: flex;
  justify-content: space-around;
  margin: 30rpx;
  padding: 30rpx;
  background-color: #FFFFFF;
  border-radius: 20rpx;
  box-shadow: 0 4rpx 20rpx rgba(255, 107, 139, 0.08);
}

.action-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.action-icon {
  width: 60rpx;
  height: 60rpx;
  margin-bottom: 15rpx;
}

.action-text {
  font-size: 24rpx;
  color: #666666;
}

/* 按钮样式 */
.btn {
  border-radius: 50rpx;
  padding: 20rpx 40rpx;
  font-size: 28rpx;
  line-height: 1;
}

.btn-primary {
  background-color: #FF6B8B;
  color: white;
}

.btn-primary:active {
  background-color: #FF5580;
  transform: scale(0.98);
}

/* 加载中 */
.loading {
  display: flex;
  justify-content: center;
  align-items: center;
  height: 200rpx;
}

.loading text {
  font-size: 28rpx;
  color: #999999;
}