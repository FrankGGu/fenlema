/* components/ai-message/ai-message.wxss */
.message-container {
  display: flex;
  margin-bottom: 40rpx;
  transition: all 0.3s ease;
}

.message-container:active {
  opacity: 0.9;
}

/* AI消息在左侧 */
.message-container.ai {
  flex-direction: row;
}

/* 用户消息在右侧 */
.message-container.user {
  flex-direction: row-reverse;
}

/* 头像 */
.message-avatar {
  position: relative;
  width: 80rpx;
  height: 80rpx;
  margin: 0 20rpx;
  flex-shrink: 0;
}

.avatar-image {
  width: 100%;
  height: 100%;
  border-radius: 50%;
  border: 3rpx solid #FFE8D6;
  background-color: #FFFFFF;
}

.avatar-icon {
  position: absolute;
  bottom: -10rpx;
  right: -10rpx;
  font-size: 32rpx;
  background-color: #FFFFFF;
  border-radius: 50%;
  width: 36rpx;
  height: 36rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 2rpx solid #F5F5F5;
}

/* 消息内容 */
.message-content {
  max-width: 70%;
  display: flex;
  flex-direction: column;
}

.message-container.ai .message-content {
  align-items: flex-start;
}

.message-container.user .message-content {
  align-items: flex-end;
}

/* 消息气泡 */
.message-bubble {
  padding: 24rpx 30rpx;
  border-radius: 24rpx;
  font-size: 28rpx;
  line-height: 1.6;
  word-break: break-word;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.08);
  position: relative;
  max-width: 100%;
}

/* AI消息气泡箭头 */
.message-container.ai .message-bubble::before {
  content: '';
  position: absolute;
  top: 20rpx;
  left: -16rpx;
  border-width: 16rpx;
  border-style: solid;
  border-color: transparent {{getMessageStyle().bgColor}} transparent transparent;
}

/* 用户消息气泡箭头 */
.message-container.user .message-bubble::before {
  content: '';
  position: absolute;
  top: 20rpx;
  right: -16rpx;
  border-width: 16rpx;
  border-style: solid;
  border-color: transparent transparent transparent {{getMessageStyle().bgColor}};
}

/* 消息文本 */
.message-text {
  margin-bottom: 20rpx;
}

/* 建议容器 */
.suggestions-container {
  margin-top: 20rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid rgba(0, 0, 0, 0.1);
}

.suggestions-title {
  font-size: 26rpx;
  font-weight: 500;
  margin-bottom: 16rpx;
  display: flex;
  align-items: center;
}

.suggestions-title .iconfont {
  margin-right: 8rpx;
  font-size: 24rpx;
}

/* 建议列表 */
.suggestions-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

/* 建议项 */
.suggestion-item {
  background-color: rgba(255, 255, 255, 0.5);
  border-radius: 16rpx;
  padding: 20rpx;
  display: flex;
  align-items: flex-start;
  transition: all 0.3s ease;
}

.suggestion-item:active {
  background-color: rgba(255, 255, 255, 0.8);
  transform: scale(0.98);
}

.suggestion-index {
  font-weight: 600;
  margin-right: 12rpx;
  flex-shrink: 0;
}

.suggestion-text {
  flex: 1;
  line-height: 1.5;
}

/* 消息元信息 */
.message-meta {
  display: flex;
  align-items: center;
  gap: 20rpx;
  margin-top: 12rpx;
  font-size: 22rpx;
  color: #8B7355;
  opacity: 0.8;
}

.message-time {
  font-size: 22rpx;
}

/* 已读状态 */
.message-read-status {
  font-size: 22rpx;
  padding: 4rpx 12rpx;
  border-radius: 12rpx;
}

.message-read-status.read {
  background-color: #E8F5E8;
  color: #5CB85C;
}

.message-read-status.unread {
  background-color: #FFE8E8;
  color: #FF6B6B;
}