/* pages/checkin/checkin.wxss */
.page-container {
  min-height: 100vh;
  background-color: #FFF9F9;
  padding-bottom: 40rpx;
}

/* 顶部提示 */
.top-tip {
  padding: 30rpx;
  text-align: center;
  background-color: #FFE8E8;
  margin-bottom: 20rpx;
}

.top-tip text {
  font-size: 28rpx;
  color: #FF6B8B;
}

/* 表单部分 */
.checkin-form {
  background-color: #FFFFFF;
  border-radius: 20rpx;
  margin: 0 30rpx 30rpx;
  padding: 30rpx;
  box-shadow: 0 4rpx 20rpx rgba(255, 107, 139, 0.08);
}

.form-section {
  margin-bottom: 40rpx;
}

.form-section:last-child {
  margin-bottom: 0;
}

.section-header {
  margin-bottom: 25rpx;
}

.section-title {
  display: block;
  font-size: 32rpx;
  font-weight: 600;
  color: #333333;
  margin-bottom: 8rpx;
}

.section-subtitle {
  display: block;
  font-size: 24rpx;
  color: #999999;
}

/* 心情选项 */
.mood-options {
  display: flex;
  justify-content: space-between;
}

.mood-option {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 20rpx;
  border-radius: 20rpx;
  border: 2rpx solid #F0F0F0;
  background-color: #FFFFFF;
  transition: all 0.3s ease;
  min-width: 120rpx;
}

.mood-option.selected {
  border-color: #FF6B8B;
  background-color: #FFE8E8;
  transform: scale(1.05);
}

.mood-emoji {
  font-size: 60rpx;
  margin-bottom: 15rpx;
}

.mood-label {
  font-size: 24rpx;
  color: #666666;
}

.mood-option.selected .mood-label {
  color: #FF6B8B;
  font-weight: 500;
}

/* 评分选项 */
.rating-options {
  display: flex;
  justify-content: space-between;
}

.rating-option {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 25rpx 15rpx;
  border-radius: 16rpx;
  border: 2rpx solid #F0F0F0;
  background-color: #FFFFFF;
  transition: all 0.3s ease;
  flex: 1;
  margin: 0 5rpx;
}

.rating-option.selected {
  border-color: #6B8BFF;
  background-color: rgba(107, 139, 255, 0.1);
  transform: scale(1.05);
}

.rating-value {
  font-size: 36rpx;
  font-weight: 700;
  color: #333333;
  margin-bottom: 10rpx;
}

.rating-option.selected .rating-value {
  color: #6B8BFF;
}

.rating-label {
  font-size: 22rpx;
  color: #666666;
  text-align: center;
  line-height: 1.3;
}

.rating-option.selected .rating-label {
  color: #6B8BFF;
  font-weight: 500;
}

/* 冲突选项 */
.conflict-options {
  display: flex;
  flex-direction: column;
}

.conflict-option {
  padding: 25rpx 30rpx;
  border-radius: 16rpx;
  border: 2rpx solid #F0F0F0;
  background-color: #FFFFFF;
  margin-bottom: 15rpx;
  transition: all 0.3s ease;
}

.conflict-option:last-child {
  margin-bottom: 0;
}

.conflict-option.selected {
  border-color: #FF6B6B;
  background-color: rgba(255, 107, 107, 0.1);
}

.conflict-label {
  font-size: 28rpx;
  color: #333333;
}

.conflict-option.selected .conflict-label {
  color: #FF6B6B;
  font-weight: 500;
}

/* 备注输入 */
.note-input {
  width: 100%;
  min-height: 200rpx;
  padding: 25rpx;
  border: 2rpx solid #F0F0F0;
  border-radius: 16rpx;
  font-size: 28rpx;
  color: #333333;
  line-height: 1.5;
  background-color: #FFFFFF;
}

.note-input:focus {
  border-color: #FF6B8B;
}

.note-count {
  text-align: right;
  margin-top: 10rpx;
}

.note-count text {
  font-size: 22rpx;
  color: #999999;
}

/* 伴侣打卡状态 */
.partner-section {
  background-color: #FFFFFF;
  border-radius: 20rpx;
  margin: 0 30rpx 30rpx;
  padding: 30rpx;
  box-shadow: 0 4rpx 20rpx rgba(107, 139, 255, 0.08);
  border-left: 8rpx solid #6B8BFF;
}

.partner-section .section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 25rpx;
}

.section-time {
  font-size: 24rpx;
  color: #999999;
}

.partner-status {
  background-color: #F8F9FF;
  border-radius: 16rpx;
  padding: 25rpx;
}

.status-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 15rpx 0;
  border-bottom: 1rpx solid #F0F0F0;
}

.status-item:last-child {
  border-bottom: none;
}

.status-label {
  font-size: 28rpx;
  color: #666666;
  width: 150rpx;
}

.status-value {
  font-size: 28rpx;
  font-weight: 500;
}

.mood-1, .conflict-5 {
  color: #FF6B6B;
}

.mood-2, .conflict-4 {
  color: #FFB86B;
}

.mood-3, .conflict-3 {
  color: #666666;
}

.mood-4, .conflict-2 {
  color: #6B8BFF;
}

.mood-5, .conflict-1 {
  color: #6BFF8B;
}

.stars {
  display: flex;
}

.star {
  font-size: 36rpx;
  margin-right: 10rpx;
}

.star.filled {
  color: #FFD700;
}

.star.empty {
  color: #F0F0F0;
}

.note-item {
  flex-direction: column;
  align-items: flex-start;
}

.status-note {
  font-size: 26rpx;
  color: #666666;
  line-height: 1.5;
  margin-top: 10rpx;
  padding: 15rpx;
  background-color: #FFFFFF;
  border-radius: 12rpx;
  width: 100%;
}

/* 操作按钮 */
.action-buttons {
  display: flex;
  justify-content: space-between;
  margin: 0 30rpx 30rpx;
  gap: 20rpx;
}

.action-buttons .btn {
  flex: 1;
}

.btn {
  border-radius: 50rpx;
  padding: 25rpx 0;
  font-size: 28rpx;
  line-height: 1;
  border: none;
}

.btn-primary {
  background-color: #FF6B8B;
  color: white;
}

.btn-primary:active {
  background-color: #FF5580;
  transform: scale(0.98);
}

.btn-secondary {
  background-color: #F0F0F0;
  color: #666666;
}

.btn-secondary:active {
  background-color: #E0E0E0;
  transform: scale(0.98);
}

.btn:disabled {
  opacity: 0.6;
}

/* 底部提示 */
.bottom-tip {
  text-align: center;
  padding: 25rpx 30rpx;
  margin: 0 30rpx;
  background-color: #E8FFED;
  border-radius: 20rpx;
}

.bottom-tip text {
  font-size: 24rpx;
  color: #6BFF8B;
  line-height: 1.5;
}