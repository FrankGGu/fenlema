/* app.wxss - 全局样式 */

/* 颜色变量 */
:root {
  --primary-color: #FF6B8B;
  --primary-light: #FFE8E8;
  --secondary-color: #6B8BFF;
  --success-color: #6BFF8B;
  --warning-color: #FFB86B;
  --danger-color: #FF6B6B;
  --text-primary: #333333;
  --text-secondary: #666666;
  --text-light: #999999;
  --background-color: #FFF9F9;
  --card-background: #FFFFFF;
  --border-color: #F0F0F0;
  --shadow-light: 0 2px 12px rgba(255, 107, 139, 0.1);
}

/* 全局样式 */
page {
  background-color: var(--background-color);
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'Roboto', 'Helvetica Neue', Arial, sans-serif;
  color: var(--text-primary);
  line-height: 1.6;
  font-size: 16px;
}

/* 容器 */
.container {
  padding: 20rpx;
}

/* 卡片样式 */
.card {
  background-color: var(--card-background);
  border-radius: 16rpx;
  padding: 30rpx;
  margin: 20rpx;
  box-shadow: var(--shadow-light);
}

/* 按钮样式 */
.btn {
  border-radius: 50rpx;
  padding: 20rpx 40rpx;
  font-size: 16px;
  text-align: center;
  transition: all 0.3s ease;
}

.btn-primary {
  background-color: var(--primary-color);
  color: white;
}

.btn-primary:active {
  background-color: #FF5580;
  transform: scale(0.98);
}

.btn-secondary {
  background-color: var(--primary-light);
  color: var(--primary-color);
}

.btn-secondary:active {
  background-color: #FFD6D6;
}

.btn-disabled {
  background-color: #F0F0F0;
  color: #CCCCCC;
}

/* 输入框样式 */
.input {
  border: 2rpx solid var(--border-color);
  border-radius: 12rpx;
  padding: 20rpx;
  font-size: 16px;
  background-color: white;
}

.input:focus {
  border-color: var(--primary-color);
  outline: none;
}

/* 标签样式 */
.tag {
  display: inline-block;
  padding: 8rpx 20rpx;
  border-radius: 30rpx;
  font-size: 12px;
  margin-right: 10rpx;
  margin-bottom: 10rpx;
}

.tag-primary {
  background-color: var(--primary-light);
  color: var(--primary-color);
}

.tag-success {
  background-color: rgba(107, 255, 139, 0.1);
  color: var(--success-color);
}

.tag-warning {
  background-color: rgba(255, 184, 107, 0.1);
  color: var(--warning-color);
}

.tag-danger {
  background-color: rgba(255, 107, 107, 0.1);
  color: var(--danger-color);
}

/* 进度条样式 */
.progress-bar {
  height: 12rpx;
  background-color: #F0F0F0;
  border-radius: 6rpx;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  background-color: var(--primary-color);
  border-radius: 6rpx;
  transition: width 0.5s ease;
}

/* 头像样式 */
.avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  overflow: hidden;
}

.avatar-lg {
  width: 120rpx;
  height: 120rpx;
}

.avatar-xl {
  width: 160rpx;
  height: 160rpx;
}

/* 文字样式 */
.text-center {
  text-align: center;
}

.text-right {
  text-align: right;
}

.text-primary {
  color: var(--primary-color);
}

.text-secondary {
  color: var(--text-secondary);
}

.text-light {
  color: var(--text-light);
}

.text-bold {
  font-weight: bold;
}

/* 间距 */
.mt-10 { margin-top: 10rpx; }
.mt-20 { margin-top: 20rpx; }
.mt-30 { margin-top: 30rpx; }
.mb-10 { margin-bottom: 10rpx; }
.mb-20 { margin-bottom: 20rpx; }
.mb-30 { margin-bottom: 30rpx; }
.ml-10 { margin-left: 10rpx; }
.mr-10 { margin-right: 10rpx; }
.p-20 { padding: 20rpx; }
.p-30 { padding: 30rpx; }

/* flex布局 */
.flex {
  display: flex;
}

.flex-column {
  flex-direction: column;
}

.flex-row {
  flex-direction: row;
}

.flex-center {
  align-items: center;
  justify-content: center;
}

.flex-between {
  justify-content: space-between;
}

.flex-around {
  justify-content: space-around;
}

.flex-wrap {
  flex-wrap: wrap;
}

/* 图标尺寸 */
.icon-sm {
  width: 40rpx;
  height: 40rpx;
}

.icon-md {
  width: 60rpx;
  height: 60rpx;
}

.icon-lg {
  width: 80rpx;
  height: 80rpx;
}

/* 动画 */
@keyframes fadeIn {
  from { opacity: 0; }
  to { opacity: 1; }
}

@keyframes slideUp {
  from { transform: translateY(20rpx); opacity: 0; }
  to { transform: translateY(0); opacity: 1; }
}

@keyframes pulse {
  0% { transform: scale(1); }
  50% { transform: scale(1.05); }
  100% { transform: scale(1); }
}

.fade-in {
  animation: fadeIn 0.5s ease;
}

.slide-up {
  animation: slideUp 0.5s ease;
}

.pulse {
  animation: pulse 2s infinite;
}

/* 关系温度计样式 */
.temperature-meter {
  width: 100%;
  height: 40rpx;
  background: linear-gradient(90deg, #FF6B6B, #FFB86B, #6BFF8B);
  border-radius: 20rpx;
  overflow: hidden;
  position: relative;
}

.temperature-indicator {
  position: absolute;
  top: -10rpx;
  width: 4rpx;
  height: 60rpx;
  background-color: #333;
  transform: translateX(-50%);
}

/* 心情表情样式 */
.mood-emoji {
  font-size: 60rpx;
  text-align: center;
}

.mood-emoji.selected {
  transform: scale(1.2);
}

/* 评分星星样式 */
.star-rating {
  display: flex;
  justify-content: center;
}

.star {
  font-size: 50rpx;
  color: #FFD700;
  margin: 0 10rpx;
}

.star.empty {
  color: #F0F0F0;
}