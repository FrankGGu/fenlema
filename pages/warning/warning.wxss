/* pages/warning/warning.wxss */
.page-container {
  min-height: 100vh;
  background-color: #FFF9F9;
  padding-bottom: 40rpx;
}

/* 加载中 */
.loading {
  display: flex;
  justify-content: center;
  align-items: center;
  height: 200rpx;
}

.loading text {
  font-size: 28rpx;
  color: #999999;
}

/* 卡片通用样式 */
.risk-card,
.stats-card,
.analysis-card,
.warnings-card,
.suggestions-card {
  background-color: #FFFFFF;
  border-radius: 20rpx;
  margin: 30rpx;
  padding: 30rpx;
  box-shadow: 0 4rpx 20rpx rgba(255, 107, 139, 0.08);
  border-left: 8rpx solid;
}

/* 风险卡片 */
.risk-card {
  border-left-color: #FF6B8B;
}

.risk-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 25rpx;
}

.risk-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333333;
}

.risk-level {
  font-size: 36rpx;
  font-weight: 700;
}

.risk-progress {
  margin: 30rpx 0;
}

.progress-bar {
  height: 20rpx;
  background-color: #F0F0F0;
  border-radius: 10rpx;
  overflow: hidden;
  position: relative;
  margin-bottom: 15rpx;
}

.progress-fill {
  height: 100%;
  border-radius: 10rpx;
  transition: width 0.5s ease;
}

.progress-indicator {
  position: absolute;
  top: -10rpx;
  width: 4rpx;
  height: 40rpx;
  background-color: #333333;
  transform: translateX(-50%);
}

.progress-labels {
  display: flex;
  justify-content: space-between;
}

.progress-label {
  font-size: 22rpx;
  color: #999999;
}

.risk-description {
  padding-top: 20rpx;
  border-top: 2rpx solid #F0F0F0;
  margin-top: 20rpx;
}

.risk-description text {
  font-size: 28rpx;
  color: #666666;
  line-height: 1.5;
}

/* 统计卡片 */
.stats-card {
  border-left-color: #6B8BFF;
}

.stats-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 25rpx;
}

.stats-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333333;
}

.stats-update {
  font-size: 24rpx;
  color: #999999;
}

.stats-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 20rpx;
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 30rpx 20rpx;
  background-color: #F8F8F8;
  border-radius: 16rpx;
}

.stat-value {
  font-size: 40rpx;
  font-weight: 700;
  color: #FF6B8B;
  margin-bottom: 10rpx;
}

.stat-label {
  font-size: 24rpx;
  color: #666666;
}

/* 分析卡片 */
.analysis-card {
  border-left-color: #FFB86B;
}

.section-header {
  margin-bottom: 25rpx;
  padding-bottom: 20rpx;
  border-bottom: 2rpx solid #F0F0F0;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333333;
}

.reasons-list {
  margin-bottom: 30rpx;
}

.reason-item {
  margin-bottom: 25rpx;
}

.reason-item:last-child {
  margin-bottom: 0;
}

.reason-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 10rpx;
}

.reason-type {
  font-size: 28rpx;
  color: #333333;
  font-weight: 500;
}

.reason-count {
  font-size: 24rpx;
  color: #999999;
}

.reason-bar {
  height: 12rpx;
  background-color: #F0F0F0;
  border-radius: 6rpx;
  overflow: hidden;
}

.bar-fill {
  height: 100%;
  background-color: #FF6B8B;
  border-radius: 6rpx;
  transition: width 0.5s ease;
}

.suggestions {
  padding-top: 25rpx;
  border-top: 2rpx solid #F0F0F0;
}

.suggestions-title {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: #333333;
  margin-bottom: 15rpx;
}

.suggestion-item {
  display: flex;
  align-items: flex-start;
  margin-bottom: 12rpx;
}

.suggestion-item:last-child {
  margin-bottom: 0;
}

.suggestion-bullet {
  font-size: 24rpx;
  color: #FF6B8B;
  margin-right: 15rpx;
  flex-shrink: 0;
  margin-top: 5rpx;
}

.suggestion-text {
  font-size: 26rpx;
  color: #666666;
  line-height: 1.5;
}

/* 预警列表卡片 */
.warnings-card {
  border-left-color: #FF6B6B;
}

.filters {
  margin-top: 20rpx;
}

.filter-group {
  display: flex;
  align-items: center;
  margin-bottom: 15rpx;
}

.filter-group:last-child {
  margin-bottom: 0;
}

.filter-label {
  font-size: 26rpx;
  color: #666666;
  width: 100rpx;
  flex-shrink: 0;
}

.filter-options {
  display: flex;
  flex-wrap: wrap;
  gap: 15rpx;
  flex: 1;
}

.filter-option {
  font-size: 24rpx;
  color: #999999;
  padding: 8rpx 20rpx;
  border: 2rpx solid #F0F0F0;
  border-radius: 20rpx;
  background-color: #FFFFFF;
}

.filter-option.active {
  color: #FF6B8B;
  border-color: #FF6B8B;
  background-color: #FFE8E8;
}

.warnings-list {
  margin-top: 20rpx;
}

.no-warnings {
  text-align: center;
  padding: 60rpx 0;
}

.no-data-text {
  display: block;
  font-size: 28rpx;
  color: #999999;
  margin-bottom: 15rpx;
}

.no-data-hint {
  display: block;
  font-size: 24rpx;
  color: #CCCCCC;
}

.warning-items {
  max-height: 600rpx;
  overflow-y: auto;
}

.warning-item {
  display: flex;
  align-items: center;
  padding: 25rpx 0;
  border-bottom: 1rpx solid #F8F8F8;
}

.warning-item:last-child {
  border-bottom: none;
}

.warning-item.handled {
  opacity: 0.7;
}

.warning-icon {
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.icon-text {
  font-size: 32rpx;
}

.warning-content {
  flex: 1;
  min-width: 0;
}

.warning-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 8rpx;
}

.warning-type {
  font-size: 28rpx;
  font-weight: 500;
  color: #333333;
}

.warning-level {
  font-size: 22rpx;
  font-weight: 500;
}

.warning-reason {
  display: block;
  font-size: 24rpx;
  color: #666666;
  margin-bottom: 8rpx;
  line-height: 1.4;
}

.warning-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.warning-date {
  font-size: 22rpx;
  color: #999999;
}

.warning-status {
  font-size: 22rpx;
  padding: 4rpx 12rpx;
  border-radius: 12rpx;
}

.status-unhandled {
  background-color: rgba(255, 107, 107, 0.1);
  color: #FF6B6B;
}

.status-handled {
  background-color: rgba(107, 255, 139, 0.1);
  color: #6BFF8B;
}

.warning-actions {
  margin-left: 20rpx;
}

.btn-handle {
  padding: 10rpx 20rpx;
  font-size: 24rpx;
  color: #FFFFFF;
  background-color: #FF6B8B;
  border: none;
  border-radius: 20rpx;
  line-height: 1;
}

.btn-handle:active {
  background-color: #FF5580;
  transform: scale(0.95);
}

.warnings-footer {
  text-align: right;
  margin-top: 20rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid #F0F0F0;
}

.clear-filters {
  color: #FF6B8B;
  font-size: 24rpx;
}

/* 建议卡片 */
.suggestions-card {
  border-left-color: #6BFF8B;
}

.suggestion-groups {
  display: flex;
  flex-direction: column;
  gap: 30rpx;
}

.suggestion-group {
  background-color: #F8F8F8;
  border-radius: 16rpx;
  padding: 25rpx;
}

.group-title {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: #333333;
  margin-bottom: 15rpx;
  padding-bottom: 10rpx;
  border-bottom: 1rpx solid #F0F0F0;
}

.group-items {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.group-item {
  display: flex;
  align-items: flex-start;
}

.item-bullet {
  font-size: 24rpx;
  color: #6B8BFF;
  margin-right: 15rpx;
  flex-shrink: 0;
  margin-top: 5rpx;
}

.item-text {
  font-size: 26rpx;
  color: #666666;
  line-height: 1.5;
}

/* 操作按钮 */
.action-buttons {
  display: flex;
  justify-content: space-between;
  margin: 0 30rpx;
  gap: 20rpx;
}

.action-buttons .btn {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 25rpx 0;
  border-radius: 20rpx;
  border: none;
  font-size: 24rpx;
  line-height: 1.2;
}

.btn-primary {
  background-color: #FF6B8B;
  color: white;
}

.btn-primary:active {
  background-color: #FF5580;
  transform: scale(0.98);
}

.btn-secondary {
  background-color: #6B8BFF;
  color: white;
}

.btn-secondary:active {
  background-color: #5570FF;
  transform: scale(0.98);
}

.btn-warning {
  background-color: #FFB86B;
  color: white;
}

.btn-warning:active {
  background-color: #FFA850;
  transform: scale(0.98);
}

.btn-icon {
  font-size: 40rpx;
  margin-bottom: 10rpx;
}

.btn-text {
  font-size: 24rpx;
}