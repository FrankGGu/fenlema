/* pages/profile/profile.wxss */
.profile-page {
  min-height: 100vh;
  background-color: #FDF6F0;
  padding-bottom: 40rpx;
}

/* 用户信息卡片 */
.user-card {
  background: linear-gradient(135deg, #FFE8D6 0%, #F5D5B8 100%);
  border-radius: 0 0 40rpx 40rpx;
  padding: 60rpx 40rpx 40rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 4rpx 20rpx rgba(212, 165, 116, 0.2);
}

.user-header {
  display: flex;
  align-items: center;
  margin-bottom: 40rpx;
}

.user-avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  border: 4rpx solid #FFFFFF;
  margin-right: 24rpx;
}

.user-info {
  flex: 1;
}

.user-nickname {
  font-size: 40rpx;
  font-weight: 600;
  color: #5C4033;
  margin-bottom: 8rpx;
}

.user-status {
  font-size: 24rpx;
  color: #8B7355;
  display: flex;
  align-items: center;
}

.user-status .status-icon {
  margin-right: 8rpx;
  color: #FF6B6B;
  font-size: 24rpx;
}

.edit-btn {
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  background-color: rgba(255, 255, 255, 0.8);
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
  padding: 0;
}

.edit-btn .iconfont {
  font-size: 28rpx;
  color: #D4A574;
}

.user-stats {
  display: flex;
  justify-content: space-between;
  background-color: rgba(255, 255, 255, 0.8);
  border-radius: 24rpx;
  padding: 30rpx;
}

.stat-item {
  flex: 1;
  text-align: center;
}

.stat-value {
  font-size: 40rpx;
  font-weight: 600;
  color: #5C4033;
  margin-bottom: 6rpx;
}

.stat-label {
  font-size: 24rpx;
  color: #8B7355;
}

/* 伴侣信息卡片 */
.partner-card {
  background-color: #FFFFFF;
  border-radius: 24rpx;
  padding: 30rpx;
  margin: 0 30rpx 30rpx;
  box-shadow: 0 4rpx 20rpx rgba(139, 115, 85, 0.08);
}

.partner-header {
  display: flex;
  align-items: center;
}

.partner-avatar {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  border: 3rpx solid #FFE8D6;
  margin-right: 24rpx;
}

.partner-info {
  flex: 1;
}

.partner-nickname {
  font-size: 32rpx;
  font-weight: 600;
  color: #5C4033;
  margin-bottom: 6rpx;
}

.partner-last-checkin {
  font-size: 24rpx;
  color: #8B7355;
  opacity: 0.8;
}

.partner-arrow .iconfont {
  font-size: 28rpx;
  color: #D4A574;
}

/* 功能菜单 */
.menu-container {
  background-color: #FFFFFF;
  border-radius: 24rpx;
  margin: 0 30rpx 30rpx;
  padding: 30rpx 0;
  box-shadow: 0 4rpx 20rpx rgba(139, 115, 85, 0.08);
}

.menu-grid {
  display: flex;
  flex-wrap: wrap;
}

.menu-item {
  width: 25%;
  text-align: center;
  padding: 20rpx 0;
  transition: all 0.3s ease;
}

.menu-item:active {
  background-color: #FDF6F0;
  border-radius: 16rpx;
}

.menu-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background-color: #FFE8D6;
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 0 auto 12rpx;
}

.menu-icon .iconfont {
  font-size: 36rpx;
  color: #D4A574;
}

.menu-title {
  font-size: 24rpx;
  color: #5C4033;
}

/* 操作按钮 */
.action-container {
  padding: 0 30rpx;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.action-btn {
  border-radius: 24rpx;
  padding: 28rpx;
  font-size: 28rpx;
  font-weight: 500;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.3s ease;
}

.action-btn .iconfont {
  margin-right: 12rpx;
  font-size: 28rpx;
}

.action-btn:active {
  opacity: 0.8;
  transform: scale(0.98);
}

.invite-btn {
  background-color: #FFE8D6;
  color: #D4A574;
}

.contact-btn {
  background-color: #E8F5E9;
  color: #5CB85C;
}

.logout-btn {
  background-color: #FFE8E8;
  color: #FF6B6B;
}

/* 模态框样式 */
.modal-container {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 999;
  display: none;
  align-items: center;
  justify-content: center;
}

.modal-container.show {
  display: flex;
}

.modal-mask {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.5);
}

.modal-content {
  position: relative;
  width: 80%;
  max-width: 600rpx;
  background-color: #FFFFFF;
  border-radius: 32rpx;
  overflow: hidden;
  box-shadow: 0 20rpx 60rpx rgba(0, 0, 0, 0.2);
}

.modal-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 40rpx 40rpx 20rpx;
  border-bottom: 2rpx solid #F5F5F5;
}

.modal-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #5C4033;
}

.modal-close {
  width: 50rpx;
  height: 50rpx;
  border-radius: 50%;
  background-color: #F5F5F5;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
  padding: 0;
}

.modal-close .iconfont {
  font-size: 24rpx;
  color: #999;
}

.modal-body {
  padding: 40rpx;
  text-align: center;
}

.modal-avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  border: 4rpx solid #FFE8D6;
  margin-bottom: 20rpx;
}

.modal-nickname {
  font-size: 36rpx;
  font-weight: 600;
  color: #5C4033;
  margin-bottom: 10rpx;
}

.modal-desc {
  font-size: 24rpx;
  color: #8B7355;
  margin-bottom: 30rpx;
}

.modal-stats {
  display: flex;
  justify-content: space-between;
  background-color: #FDF6F0;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-top: 20rpx;
}

.modal-stat {
  flex: 1;
  text-align: center;
}

.modal-stat .stat-label {
  display: block;
  font-size: 22rpx;
  color: #8B7355;
  margin-bottom: 6rpx;
}

.modal-stat .stat-value {
  display: block;
  font-size: 32rpx;
  font-weight: 600;
  color: #5C4033;
}

.modal-warning {
  font-size: 60rpx;
  color: #FFB74D;
  display: block;
  margin-bottom: 20rpx;
}

.modal-message {
  font-size: 28rpx;
  color: #5C4033;
  line-height: 1.6;
}

.modal-footer {
  display: flex;
  padding: 0 40rpx 40rpx;
  gap: 20rpx;
}

.modal-btn {
  flex: 1;
  border-radius: 20rpx;
  padding: 24rpx;
  font-size: 28rpx;
  font-weight: 500;
  border: none;
  transition: all 0.3s ease;
}

.modal-btn:active {
  opacity: 0.8;
  transform: scale(0.98);
}

.modal-btn.primary {
  background-color: #FFE8D6;
  color: #D4A574;
}

.modal-btn.secondary {
  background-color: #F5F5F5;
  color: #666;
}

.modal-btn.cancel {
  background-color: #F5F5F5;
  color: #666;
}

.modal-btn.confirm {
  background-color: #FFE8E8;
  color: #FF6B6B;
}