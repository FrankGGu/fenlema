/* components/relationship-thermometer/relationship-thermometer.wxss */
.thermometer-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 20rpx;
  transition: all 0.3s ease;
}

.thermometer-container:active {
  opacity: 0.9;
  transform: scale(0.98);
}

/* 尺寸样式 */
.thermometer-container.small {
  padding: 10rpx;
}

.thermometer-container.small .thermometer {
  width: 60rpx;
  height: 200rpx;
}

.thermometer-container.small .temperature-value {
  font-size: 24rpx;
}

.thermometer-container.medium .thermometer {
  width: 80rpx;
  height: 260rpx;
}

.thermometer-container.large .thermometer {
  width: 100rpx;
  height: 320rpx;
}

/* 温度计主体 */
.thermometer {
  position: relative;
  margin-bottom: 30rpx;
}

/* 温度计背景 */
.thermometer-bg {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: calc(100% - 60rpx);
  background-color: #F5F5F5;
  border-radius: 40rpx;
  overflow: hidden;
  border: 4rpx solid #E0E0E0;
}

/* 温度计刻度 */
.thermometer-scale {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  z-index: 1;
}

.scale-item {
  position: absolute;
  right: 120%;
  font-size: 20rpx;
  color: #8B7355;
  opacity: 0.7;
  transform: translateY(50%);
}

/* 温度计液体 */
.thermometer-liquid {
  position: absolute;
  bottom: 0;
  left: 0;
  width: 100%;
  border-radius: 40rpx;
  transition: height 0.8s ease, background-color 0.8s ease;
  z-index: 0;
}

/* 温度计球体 */
.thermometer-bulb {
  position: absolute;
  bottom: -40rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 120%;
  height: 60rpx;
  border-radius: 50%;
  background-color: #D4A574;
  transition: background-color 0.8s ease;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.1);
}

/* 温度值 */
.temperature-value {
  position: absolute;
  top: 50%;
  left: 120%;
  transform: translateY(-50%);
  font-size: 36rpx;
  font-weight: 600;
  min-width: 80rpx;
  text-align: left;
  transition: color 0.8s ease;
}

.thermometer-container.small .temperature-value {
  left: 110%;
  font-size: 24rpx;
}

/* 温度信息 */
.temperature-info {
  text-align: center;
  width: 100%;
}

.temperature-header {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  margin-bottom: 16rpx;
}

.temperature-icon {
  font-size: 36rpx;
}

.temperature-level {
  font-size: 28rpx;
  font-weight: 500;
  color: #5C4033;
}

.temperature-level.excellent {
  color: #5CB85C;
}

.temperature-level.good {
  color: #A8D5BA;
}

.temperature-level.normal {
  color: #D4A574;
}

.temperature-level.low {
  color: #FFB6C1;
}

.temperature-level.critical {
  color: #FF6B6B;
}

.trend-arrow {
  font-size: 28rpx;
  font-weight: 500;
}

/* 温度描述 */
.temperature-desc {
  font-size: 24rpx;
  color: #8B7355;
  line-height: 1.6;
  opacity: 0.9;
  padding: 0 20rpx;
}