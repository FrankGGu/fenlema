<!--pages/profile/profile.wxml-->
<view class="profile-page">
  <!-- 用户信息卡片 -->
  <view class="user-card">
    <view class="user-header">
      <image class="user-avatar" src="{{userInfo.avatar}}" mode="aspectFill"></image>
      <view class="user-info">
        <view class="user-nickname">{{userInfo.nickname}}</view>
        <view class="user-status">
          <text class="status-icon iconfont icon-heart"></text>
          关系状态：{{userInfo.relationshipStatus}}
        </view>
      </view>
      <button class="edit-btn" bindtap="onEditProfile">
        <text class="iconfont icon-edit"></text>
      </button>
    </view>

    <view class="user-stats">
      <view class="stat-item">
        <view class="stat-value">{{userInfo.relationshipDays}}</view>
        <view class="stat-label">关系天数</view>
      </view>
      <view class="stat-item">
        <view class="stat-value">{{userInfo.checkinDays}}</view>
        <view class="stat-label">打卡天数</view>
      </view>
      <view class="stat-item">
        <view class="stat-value">{{userInfo.checkinDays / userInfo.relationshipDays * 100 | fixed(0)}}%</view>
        <view class="stat-label">打卡率</view>
      </view>
    </view>
  </view>

  <!-- 伴侣信息 -->
  <view class="partner-card" bindtap="onViewPartner">
    <view class="partner-header">
      <image class="partner-avatar" src="{{partnerInfo.avatar}}" mode="aspectFill"></image>
      <view class="partner-info">
        <view class="partner-nickname">{{partnerInfo.nickname}}</view>
        <view class="partner-last-checkin">
          上次打卡：{{partnerInfo.lastCheckin}}
        </view>
      </view>
      <view class="partner-arrow">
        <text class="iconfont icon-arrow-right"></text>
      </view>
    </view>
  </view>

  <!-- 功能菜单 -->
  <view class="menu-container">
    <view class="menu-grid">
      <block wx:for="{{menuItems}}" wx:key="id">
        <view class="menu-item" data-url="{{item.url}}" bindtap="onMenuItemTap">
          <view class="menu-icon">
            <text class="iconfont icon-{{item.icon}}"></text>
          </view>
          <view class="menu-title">{{item.title}}</view>
        </view>
      </block>
    </view>
  </view>

  <!-- 操作按钮 -->
  <view class="action-container">
    <button class="action-btn invite-btn" bindtap="onInvitePartner">
      <text class="iconfont icon-invite"></text> 邀请伴侣加入
    </button>
    <button class="action-btn contact-btn" bindtap="onContactService">
      <text class="iconfont icon-service"></text> 联系客服
    </button>
    <button class="action-btn logout-btn" bindtap="onShowLogoutConfirm">
      <text class="iconfont icon-logout"></text> 退出登录
    </button>
  </view>

  <!-- 伴侣信息模态框 -->
  <view class="modal-container {{showPartnerModal ? 'show' : ''}}">
    <view class="modal-mask" bindtap="onClosePartnerModal"></view>
    <view class="modal-content">
      <view class="modal-header">
        <view class="modal-title">伴侣信息</view>
        <button class="modal-close" bindtap="onClosePartnerModal">
          <text class="iconfont icon-close"></text>
        </button>
      </view>
      <view class="modal-body">
        <image class="modal-avatar" src="{{partnerInfo.avatar}}" mode="aspectFill"></image>
        <view class="modal-nickname">{{partnerInfo.nickname}}</view>
        <view class="modal-desc">已加入关系空间 {{userInfo.relationshipDays}} 天</view>
        
        <view class="modal-stats">
          <view class="modal-stat">
            <text class="stat-label">打卡率</text>
            <text class="stat-value">92%</text>
          </view>
          <view class="modal-stat">
            <text class="stat-label">平均心情</text>
            <text class="stat-value">7.8</text>
          </view>
          <view class="modal-stat">
            <text class="stat-label">最近沟通</text>
            <text class="stat-value">良好</text>
          </view>
        </view>
      </view>
      <view class="modal-footer">
        <button class="modal-btn primary" bindtap="onInvitePartner">发送提醒</button>
        <button class="modal-btn secondary" bindtap="onClosePartnerModal">关闭</button>
      </view>
    </view>
  </view>

  <!-- 退出登录确认模态框 -->
  <view class="modal-container {{showLogoutModal ? 'show' : ''}}">
    <view class="modal-mask" bindtap="onCloseLogoutModal"></view>
    <view class="modal-content">
      <view class="modal-header">
        <view class="modal-title">确认退出</view>
        <button class="modal-close" bindtap="onCloseLogoutModal">
          <text class="iconfont icon-close"></text>
        </button>
      </view>
      <view class="modal-body">
        <text class="modal-warning iconfont icon-warning"></text>
        <view class="modal-message">
          退出登录后将无法使用打卡、AI调解等功能，是否确认退出？
        </view>
      </view>
      <view class="modal-footer">
        <button class="modal-btn cancel" bindtap="onCloseLogoutModal">取消</button>
        <button class="modal-btn confirm" bindtap="onConfirmLogout">确认退出</button>
      </view>
    </view>
  </view>
</view>