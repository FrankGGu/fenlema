/* pages/mood/mood.wxss */
.page-container {
  min-height: 100vh;
  background-color: #FFF9F9;
  padding-bottom: 40rpx;
}

/* 加载中 */
.loading {
  display: flex;
  justify-content: center;
  align-items: center;
  height: 200rpx;
}

.loading text {
  font-size: 28rpx;
  color: #999999;
}

/* 卡片通用样式 */
.intro-card,
.input-card,
.stats-card,
.history-card,
.recommended-card {
  background-color: #FFFFFF;
  border-radius: 20rpx;
  margin: 30rpx;
  padding: 30rpx;
  box-shadow: 0 4rpx 20rpx rgba(255, 107, 139, 0.08);
}

/* 介绍卡片 */
.intro-card {
  border-left: 8rpx solid #6BFF8B;
  background-color: #F0FFF4;
}

.intro-header {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}

.intro-icon {
  font-size: 50rpx;
  margin-right: 20rpx;
}

.intro-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333333;
}

.intro-text {
  font-size: 26rpx;
  color: #666666;
  line-height: 1.6;
}

/* 输入卡片 */
.input-card {
  border-left: 8rpx solid #FF6B8B;
}

.section-header {
  margin-bottom: 25rpx;
  padding-bottom: 20rpx;
  border-bottom: 2rpx solid #F0F0F0;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333333;
}

.content-input {
  width: 100%;
  min-height: 300rpx;
  padding: 25rpx;
  background-color: #F8F8F8;
  border-radius: 16rpx;
  font-size: 28rpx;
  color: #333333;
  line-height: 1.6;
  border: 2rpx solid transparent;
  margin-bottom: 15rpx;
}

.content-input:focus {
  border-color: #FF6B8B;
  background-color: #FFFFFF;
}

.input-footer {
  text-align: right;
  margin-bottom: 30rpx;
}

.char-count {
  font-size: 22rpx;
  color: #999999;
}

/* 情绪标签 */
.emotion-tags {
  margin-bottom: 30rpx;
}

.tags-title {
  display: block;
  font-size: 28rpx;
  color: #333333;
  font-weight: 500;
  margin-bottom: 20rpx;
}

.tags-grid {
  display: grid;
  grid-template-columns: repeat(5, 1fr);
  gap: 15rpx;
}

.tag-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 20rpx 10rpx;
  border: 2rpx solid #F0F0F0;
  border-radius: 16rpx;
  background-color: #FFFFFF;
  transition: all 0.3s ease;
}

.tag-item.selected {
  border-color: #FF6B8B;
  background-color: #FFE8E8;
  transform: scale(1.05);
}

.tag-emoji {
  font-size: 40rpx;
  margin-bottom: 10rpx;
}

.tag-name {
  font-size: 22rpx;
  color: #333333;
}

.tag-item.selected .tag-name {
  color: #FF6B8B;
  font-weight: 500;
}

/* 匿名选项 */
.anonymous-option {
  margin-bottom: 30rpx;
  padding: 25rpx;
  background-color: #F8F8F8;
  border-radius: 16rpx;
}

.option-item {
  display: flex;
  align-items: center;
  margin-bottom: 15rpx;
}

.checkbox {
  width: 40rpx;
  height: 40rpx;
  border: 2rpx solid #F0F0F0;
  border-radius: 8rpx;
  margin-right: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: #FFFFFF;
}

.checkbox.checked {
  background-color: #FF6B8B;
  border-color: #FF6B8B;
}

.checkmark {
  color: white;
  font-size: 24rpx;
  font-weight: bold;
}

.option-text {
  font-size: 28rpx;
  color: #333333;
  font-weight: 500;
}

.option-hint {
  display: block;
  font-size: 24rpx;
  color: #999999;
  line-height: 1.5;
  padding-left: 60rpx;
}

/* 提交按钮 */
.btn-submit {
  width: 100%;
  padding: 30rpx;
  background-color: #FF6B8B;
  color: white;
  border: none;
  border-radius: 50rpx;
  font-size: 32rpx;
  font-weight: 500;
}

.btn-submit:active {
  background-color: #FF5580;
  transform: scale(0.98);
}

/* 统计卡片 */
.stats-card {
  border-left: 8rpx solid #6B8BFF;
}

.stats-period {
  font-size: 24rpx;
  color: #999999;
}

.emotion-stats {
  margin-top: 20rpx;
}

.stat-item {
  margin-bottom: 25rpx;
}

.stat-item:last-child {
  margin-bottom: 0;
}

.stat-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 10rpx;
}

.stat-emoji {
  font-size: 32rpx;
  margin-right: 15rpx;
}

.stat-name {
  font-size: 28rpx;
  color: #333333;
  font-weight: 500;
  flex: 1;
}

.stat-count {
  font-size: 24rpx;
  color: #999999;
}

.stat-bar {
  height: 12rpx;
  background-color: #F0F0F0;
  border-radius: 6rpx;
  overflow: hidden;
  margin-bottom: 8rpx;
}

.bar-fill {
  height: 100%;
  background-color: #FF6B8B;
  border-radius: 6rpx;
  transition: width 0.5s ease;
}

.stat-percentage {
  font-size: 22rpx;
  color: #FF6B8B;
  font-weight: 500;
  text-align: right;
}

/* 历史记录卡片 */
.history-card {
  border-left: 8rpx solid #FFB86B;
}

.filters {
  margin-top: 20rpx;
}

.filter-group {
  display: flex;
  align-items: center;
  margin-bottom: 15rpx;
}

.filter-group:last-child {
  margin-bottom: 0;
}

.filter-label {
  font-size: 26rpx;
  color: #666666;
  width: 100rpx;
  flex-shrink: 0;
}

.filter-tags,
.filter-dates {
  display: flex;
  flex-wrap: wrap;
  gap: 15rpx;
  flex: 1;
}

.filter-tag,
.filter-date {
  font-size: 24rpx;
  color: #999999;
  padding: 8rpx 20rpx;
  border: 2rpx solid #F0F0F0;
  border-radius: 20rpx;
  background-color: #FFFFFF;
}

.filter-tag.active,
.filter-date.active {
  color: #FF6B8B;
  border-color: #FF6B8B;
  background-color: #FFE8E8;
}

.records-list {
  margin-top: 20rpx;
}

.no-records {
  text-align: center;
  padding: 60rpx 0;
}

.no-data-text {
  display: block;
  font-size: 28rpx;
  color: #999999;
  margin-bottom: 15rpx;
}

.no-data-hint {
  display: block;
  font-size: 24rpx;
  color: #CCCCCC;
}

.record-items {
  max-height: 600rpx;
  overflow-y: auto;
}

.record-item {
  padding: 30rpx 0;
  border-bottom: 1rpx solid #F8F8F8;
}

.record-item:last-child {
  border-bottom: none;
}

.record-content {
  margin-bottom: 20rpx;
}

.record-text {
  display: block;
  font-size: 28rpx;
  color: #333333;
  line-height: 1.6;
  margin-bottom: 15rpx;
}

.record-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
}

.record-tag {
  display: flex;
  align-items: center;
  padding: 8rpx 15rpx;
  background-color: #F8F8F8;
  border-radius: 20rpx;
  font-size: 22rpx;
}

.record-tag .tag-emoji {
  font-size: 24rpx;
  margin-right: 8rpx;
}

.record-tag .tag-name {
  color: #666666;
}

.record-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.record-date {
  font-size: 22rpx;
  color: #999999;
}

.record-anonymous {
  font-size: 22rpx;
  color: #999999;
  background-color: #F8F8F8;
  padding: 6rpx 15rpx;
  border-radius: 20rpx;
}

.history-footer {
  text-align: right;
  margin-top: 20rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid #F0F0F0;
}

.clear-filters {
  color: #FF6B8B;
  font-size: 24rpx;
}

/* 推荐卡片 */
.recommended-card {
  border-left: 8rpx solid #FF6B8B;
}

.recommended-count {
  font-size: 24rpx;
  color: #FF6B8B;
  background-color: #FFE8E8;
  padding: 8rpx 16rpx;
  border-radius: 20rpx;
}

.recommended-list {
  margin-top: 10rpx;
}

.recommended-item {
  padding: 25rpx;
  background-color: #F8F8F8;
  border-radius: 16rpx;
  margin-bottom: 20rpx;
}

.recommended-item:last-child {
  margin-bottom: 0;
}

.recommended-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 15rpx;
}

.recommended-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #333333;
}

.recommended-type {
  font-size: 22rpx;
  padding: 6rpx 15rpx;
  border-radius: 20rpx;
  font-weight: 500;
}

.type-audio {
  background-color: rgba(107, 139, 255, 0.1);
  color: #6B8BFF;
}

.type-text {
  background-color: rgba(255, 184, 107, 0.1);
  color: #FFB86B;
}

.type-card {
  background-color: rgba(107, 255, 139, 0.1);
  color: #6BFF8B;
}

.recommended-description {
  display: block;
  font-size: 26rpx;
  color: #666666;
  line-height: 1.5;
  margin-bottom: 15rpx;
}

.recommended-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.recommended-duration {
  font-size: 22rpx;
  color: #999999;
}

.recommended-reason {
  font-size: 22rpx;
  color: #999999;
  font-style: italic;
  flex: 1;
  margin: 0 20rpx;
}

.btn-view {
  padding: 10rpx 20rpx;
  font-size: 22rpx;
  background-color: #FF6B8B;
  color: white;
  border: none;
  border-radius: 20rpx;
  line-height: 1;
  white-space: nowrap;
}

.btn-view:active {
  background-color: #FF5580;
  transform: scale(0.95);
}

/* 操作按钮 */
.action-buttons {
  display: flex;
  justify-content: space-between;
  margin: 0 30rpx;
  gap: 20rpx;
}

.action-buttons .btn {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 25rpx 0;
  border-radius: 20rpx;
  border: none;
  font-size: 24rpx;
  line-height: 1.2;
}

.btn-primary {
  background-color: #FF6B8B;
  color: white;
}

.btn-primary:active {
  background-color: #FF5580;
  transform: scale(0.98);
}

.btn-secondary {
  background-color: #F0F0F0;
  color: #666666;
}

.btn-secondary:active {
  background-color: #E0E0E0;
  transform: scale(0.98);
}

.btn-icon {
  font-size: 40rpx;
  margin-bottom: 10rpx;
}

.btn-text {
  font-size: 24rpx;
}

/* 弹窗样式 */
.modal-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
  padding: 30rpx;
}

.modal-container {
  background-color: #FFFFFF;
  border-radius: 30rpx;
  width: 100%;
  max-width: 600rpx;
  max-height: 80vh;
  display: flex;
  flex-direction: column;
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx;
  border-bottom: 2rpx solid #F0F0F0;
}

.modal-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333333;
}

.modal-close {
  font-size: 50rpx;
  color: #999999;
  line-height: 1;
}

.modal-content {
  flex: 1;
  padding: 30rpx;
  overflow-y: auto;
}

.record-detail {
  display: flex;
  flex-direction: column;
  gap: 25rpx;
}

.detail-content {
  font-size: 28rpx;
  color: #333333;
  line-height: 1.6;
  padding: 25rpx;
  background-color: #F8F8F8;
  border-radius: 16rpx;
}

.detail-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 15rpx;
}

.detail-tag {
  display: flex;
  align-items: center;
  padding: 15rpx 20rpx;
  background-color: #FFE8E8;
  border-radius: 20rpx;
}

.detail-tag-emoji {
  font-size: 32rpx;
  margin-right: 15rpx;
}

.detail-tag-name {
  font-size: 26rpx;
  color: #FF6B8B;
  font-weight: 500;
}

.detail-info {
  display: flex;
  flex-direction: column;
  gap: 15rpx;
  padding: 25rpx;
  background-color: #F8F8F8;
  border-radius: 16rpx;
}

.info-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.info-label {
  font-size: 26rpx;
  color: #666666;
}

.info-value {
  font-size: 26rpx;
  color: #333333;
  font-weight: 500;
}

.modal-footer {
  display: flex;
  justify-content: space-between;
  padding: 25rpx 30rpx;
  border-top: 2rpx solid #F0F0F0;
  gap: 20rpx;
}

.modal-footer .btn {
  flex: 1;
  padding: 25rpx 0;
  border-radius: 50rpx;
  font-size: 28rpx;
  border: none;
}

.modal-footer .btn-secondary {
  background-color: #FF6B6B;
  color: white;
}

.modal-footer .btn-secondary:active {
  background-color: #FF5555;
  transform: scale(0.98);
}

.modal-footer .btn-primary {
  background-color: #FF6B8B;
  color: white;
}

.modal-footer .btn-primary:active {
  background-color: #FF5580;
  transform: scale(0.98);
}